# Copy this file to .env and configure one provider locally.
# AI/ML API uses its OpenAI-compatible chat-completions endpoint.
AI_PROVIDER=aimlapi
AIMLAPI_API_KEY=
# Choose an AI/ML API chat model available to your account.
AIMLAPI_MODEL=openai/gpt-5.6-luna
# Search-capable model used only for grounded Evidence retrieval; same API key.
AIMLAPI_EVIDENCE_MODEL=perplexity/sonar

# Alternative OpenAI configuration.
# AI_PROVIDER=openai
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4.1-mini

# Operational limits.
PROVIDER_TIMEOUT_SECONDS=60
PROVIDER_RETRY_ATTEMPTS=3
REASONING_TIMEOUT_SECONDS=180
RATE_LIMIT_REQUESTS=10
RATE_LIMIT_WINDOW_SECONDS=60
TRUST_PROXY_HEADERS=false
PORT=8000
THESISION_DATA_DIR=/app/data
